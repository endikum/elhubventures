{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": "index.html,index.css,content_calendar.csv,insights/**",
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/resources",
      "destination": "/api/index"
    },
    {
      "source": "/resources/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/insights/(.*)",
      "destination": "/api/index"
    }
  ],
  "cleanUrls": true
}
